@page
@model IndexModel
@{
    ViewData["Title"] = "Chat";
}

<div class="max-w-3xl mx-auto">
    <h1 class="text-2xl font-bold text-gray-800 mb-2">Chat with the Hotel Concierge</h1>
    <p class="text-gray-500 mb-6">Ask about hotels, check availability, or book a room in Seattle.</p>

    <!-- Conversation -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 mb-6 min-h-[200px] max-h-[500px] overflow-y-auto">
        @if (Model.Conversation.Count == 0)
        {
            <div class="p-8 text-center text-gray-400">
                <p class="text-4xl mb-3">💬</p>
                <p>Start a conversation! Try asking:</p>
                <p class="text-sm mt-2 italic">"Find me a hotel near Pike Place Market for 2 guests"</p>
            </div>
        }
        else
        {
            <div class="divide-y divide-gray-100">
                @foreach (var msg in Model.Conversation)
                {
                    @if (msg.IsUser)
                    {
                        <div class="p-4 bg-emerald-50">
                            <div class="flex items-start gap-3">
                                <span class="text-lg">👤</span>
                                <div class="text-sm text-gray-800">@msg.Text</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="p-4">
                            <div class="flex items-start gap-3">
                                <span class="text-lg">🏨</span>
                                <div class="text-sm text-gray-700 whitespace-pre-wrap">@msg.Text</div>
                            </div>
                        </div>
                    }
                }
            </div>
        }
    </div>

    <!-- Input -->
    <form method="post" class="flex gap-3">
        <input type="text"
               name="userMessage"
               value="@Model.PrefilledMessage"
               placeholder="Ask about hotels in Seattle..."
               class="flex-1 rounded-lg border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent"
               required
               autofocus
               autocomplete="off" />
        <button type="submit"
                class="bg-emerald-600 text-white px-6 py-3 rounded-lg text-sm font-medium hover:bg-emerald-700 transition-colors focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">
            Send
        </button>
    </form>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="mt-4 p-4 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700">
            @Model.ErrorMessage
        </div>
    }

    <!-- Clear conversation -->
    @if (Model.Conversation.Count > 0)
    {
        <form method="post" asp-page-handler="Clear" class="mt-3">
            <button type="submit" class="text-sm text-gray-400 hover:text-gray-600 transition-colors">
                Clear conversation
            </button>
        </form>
    }
</div>
