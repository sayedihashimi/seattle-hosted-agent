<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Seattle Hotel Concierge</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="h-full bg-gray-50 text-gray-900 flex flex-col">
    <!-- Nav -->
    <nav class="bg-emerald-700 text-white shadow-lg">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <a href="/" class="text-xl font-bold tracking-tight flex items-center gap-2">
                    <span class="text-2xl">🏨</span> Seattle Hotel Concierge
                </a>
                <div class="flex gap-6 text-sm font-medium">
                    <a href="/" class="hover:text-emerald-200 transition-colors">Chat</a>
                    <a href="/Hotels" class="hover:text-emerald-200 transition-colors">Hotels</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main -->
    <main class="flex-1">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            @RenderBody()
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-gray-100 border-t border-gray-200 py-4">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-sm text-gray-500">
            Seattle Hotel Concierge &mdash; Powered by Azure AI Foundry &amp; the Responses Protocol
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
